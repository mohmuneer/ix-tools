    "tools": {
      "webBrowser": {
        "role": "Zugangsschnittstelle",
        "desc": "Der Webbrowser ist der Haupteinstiegspunkt des Benutzers. Er lädt Oracle Forms über das Java-Plugin und rendert die interaktive Systemoberfläche.",
        "benefit": "Ermöglicht schnellen Zugang von jedem vernetzten Gerät ohne zusätzliche Softwareinstallation."
      },
      "javaJre": {
        "role": "Formular-Engine",
        "desc": "Java Runtime Environment 8 führt Oracle Forms als Applets im Browser über das Java-Plugin aus.",
        "benefit": "Bietet eine einheitliche Laufzeitumgebung für alle Systemformulare und gewährleistet die Kompatibilität zwischen Java-Versionen."
      },
      "posTerminal": {
        "role": "Point of Sale",
        "desc": "Das POS-Terminal übernimmt den Direktdruck und die Barcode-Generierung in Geschäften.",
        "benefit": "Integriert sich mit ONYX-IX zur Verarbeitung von Verkaufstransaktionen."
      },
      "weblogic": {
        "role": "Anwendungsserver",
        "desc": "Oracle WebLogic 10.3.6 ist der Java-Anwendungsserver, der Forms & Reports Server hostet.",
        "benefit": "Bietet eine stabile und skalierbare Umgebung zur Verwaltung gleichzeitiger Benutzerlasten."
      },
      "formsReports": {
        "role": "Forms & Reports Engine",
        "desc": "Oracle Forms & Reports 11g führt ERP-Formulare aus und generiert dynamische Berichte.",
        "benefit": "Bildet den Kern der Geschäftslogik und wandelt Rohdaten in interaktive Berichte um."
      },
      "ordsApex": {
        "role": "REST & Web-Schnittstelle",
        "desc": "Oracle REST Data Services (ORDS) und APEX bieten eine leichtgewichtige Web-Schnittstelle und REST-API-Dienste.",
        "benefit": "Ermöglicht Web-Zugang ohne Oracle Forms und vereinfacht die Integration mit externen Systemen."
      },
      "reportsServers": {
        "role": "Berichtsserver",
        "desc": "Der Berichtsserver generiert gedruckte Berichte (PDF, HTML, Excel) aus Oracle Database Daten.",
        "benefit": "Trennt Datenpräsentation vom Ausgabeformat und ermöglicht die Berichtsanpassung."
      },
      "jdk": {
        "role": "Entwicklungspaket",
        "desc": "Java Development Kit 7 bietet die Entwicklungskompilationswerkzeuge für Oracle Forms.",
        "benefit": "Bietet eine Entwicklungsumgebung, die mit WebLogic 10.3.6 und Forms 11g kompatibel ist."
      },
      "sslHttps": {
        "role": "Sicherheit & Verschlüsselung",
        "desc": "SSL/HTTPS verschlüsselt Webverbindungen zwischen Browser und Anwendungsserver.",
        "benefit": "Gewährleistet Transportsicherheit und erfüllt Governance- und Compliance-Anforderungen."
      },
      "oracleDb": {
        "role": "Datenbank",
        "desc": "Oracle Database 21c ist die Kerndatenbank, die alle Systemdaten speichert.",
        "benefit": "Bietet die höchste Leistung, Zuverlässigkeit und Sicherheit für Unternehmensdaten."
      },
      "oracleLinux": {
        "role": "Betriebssystem",
        "desc": "Oracle Linux 8.9 ist das Betriebssystem, das Datenbank und Anwendungsserver mit installiertem UEK betreibt.",
        "benefit": "Bietet eine stabile, für Oracle Database und WebLogic optimierte Umgebung."
      }
    },
    "journey": {
      "title": "Typischer Anfrageablauf",
      "step1": {
        "title": "Systemlink öffnen und Formulare laden",
        "desc": "Der Benutzer öffnet den Systemlink im Browser und Oracle Forms lädt über das Java-Plugin (JRE)."
      },
      "step2": {
        "title": "Anfrage an Anwendungsserver senden",
